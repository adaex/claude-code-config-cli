{
  "name": "code-config-cli",
  "version": "1.9.0",
  "description": "Claude Code / Codex 等 coding agent CLI 的本地代理生命周期管理工具",
  "keywords": [
    "claude",
    "claude-code",
    "codex",
    "cli",
    "config",
    "proxy"
  ],
  "author": "adaex",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/adaex/code-config-cli.git"
  },
  "homepage": "https://github.com/adaex/code-config-cli",
  "bin": {
    "ccc": "dist/cli.js",
    "code-config-cli": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --fix src/ tests/",
    "format": "biome format --write src/ tests/",
    "format:check": "biome format src/ tests/",
    "test": "node --experimental-transform-types --test tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run test",
    "prepublishOnly": "npm run check && npm run build"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  }
}
